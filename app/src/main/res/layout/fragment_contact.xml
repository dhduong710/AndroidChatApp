<?xml version="1.0" encoding="utf-8"?>
<!--
  This is the layout file for the Contact screen, which combines two main features:
  1. Displaying incoming friend requests.
  2. Searching for new users to add as friends.
  A NestedScrollView is used as the root to allow the entire content to scroll
  if it overflows the screen, which is useful on smaller devices.
-->
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- A vertical LinearLayout to stack the different sections of the screen. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Title for the Friend Requests section. -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Friend Requests"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#D90429"
            android:layout_marginBottom="8dp"/>

        <!--
          RecyclerView to display the list of incoming friend requests.
          - nestedScrollingEnabled="false": This is important when a RecyclerView is inside
            a NestedScrollView to ensure smooth scrolling behavior and prevent conflicts.
        -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvFriendRequests"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            android:layout_marginBottom="24dp"/>

        <!-- A horizontal line to visually separate the two sections of the screen. -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"
            android:layout_marginBottom="24dp"/>

        <!-- Title for the user search section. -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Find New Friends"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#D90429"
            android:layout_marginBottom="16dp"/>

        <!-- A horizontal LinearLayout to group the search input and button side-by-side. -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!--
              The input field for the user to type the email they want to search for.
              - layout_weight="1": Makes the EditText expand to fill available horizontal space.
            -->
            <EditText
                android:id="@+id/etSearchEmail"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:hint="Enter email..."
                android:inputType="textEmailAddress"
                android:background="@android:drawable/editbox_background"/>

            <!-- The button that triggers the search action. -->
            <Button
                android:id="@+id/btnSearch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Search"
                android:backgroundTint="#D90429"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        <!--
          RecyclerView to display the list of users found from the search.
          - nestedScrollingEnabled="false": Also disabled here for smooth scrolling
            within the parent NestedScrollView.
        -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvUserList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            android:layout_marginTop="16dp"/>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
